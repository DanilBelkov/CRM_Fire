<Window x:Class="TheatreCRM.App.FilterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Фильтр" Height="480" Width="520"
        Background="#101413" WindowStartupLocation="CenterOwner"
        BorderBrush="#1E2A26" BorderThickness="1">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#EEF5F1"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="#EEF5F1"/>
            <Setter Property="Background" Value="#17201D"/>
            <Setter Property="BorderBrush" Value="#2B3A35"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="9,7"/>
            <Setter Property="Margin" Value="0,4,0,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <!-- Задаем CornerRadius для этого Border -->
                        <Border CornerRadius="8" 
Background="{TemplateBinding Background}"
BorderBrush="{TemplateBinding BorderBrush}"
BorderThickness="{TemplateBinding BorderThickness}">

                            <!-- Обязательный хост для отображения текста -->
                            <ScrollViewer x:Name="PART_ContentHost" 
          Margin="4,0" 
          VerticalAlignment="Top"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,4,0,12"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#EEF5F1"/>
            <Setter Property="Background" Value="#1D2925"/>
            <Setter Property="BorderBrush" Value="#2B3A35"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,9"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <DockPanel Margin="24">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
            <Button Content="Отмена" Click="CancelButton_Click" MinWidth="96" Margin="0,4,10,4" Padding="18,9"/>
            <Button Content="Применить" Click="ApplyButton_Click" MinWidth="120" Padding="18,9" Background="#21A66B" Foreground="#06110C"/>
        </StackPanel>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Фильтр" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16"/>
                <StackPanel x:Name="FilterFields"/>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>