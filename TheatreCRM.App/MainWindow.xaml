<Window x:Class="TheatreCRM.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:TheatreCRM.App.Models"
        Title="Театральная CRM" Height="760" Width="1240"
        MinHeight="640" MinWidth="1040"
        Background="#101413" WindowStartupLocation="CenterScreen"
        BorderBrush="#1E2A26" BorderThickness="1">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#EEF5F1"/>
            <Setter Property="Background" Value="#1D2925"/>
            <Setter Property="BorderBrush" Value="#2B3A35"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,9"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#21A66B"/>
            <Setter Property="BorderBrush" Value="#2CC77F"/>
            <Setter Property="Foreground" Value="#06110C"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="#EEF5F1"/>
            <Setter Property="Background" Value="#17201D"/>
            <Setter Property="BorderBrush" Value="#2B3A35"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <!-- Задаем CornerRadius для этого Border -->
                        <Border CornerRadius="8" 
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">

                            <!-- Обязательный хост для отображения текста -->
                            <ScrollViewer x:Name="PART_ContentHost" 
                                  Margin="4,0" 
                                  VerticalAlignment="Top"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*" MinWidth="500"/>
            <ColumnDefinition Width="Auto" MinWidth="6"/>
            <ColumnDefinition Width="4*" MinWidth="300"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель: навигация и настройки -->
        <Border Grid.Column="0" Background="#0C100F" BorderBrush="#1E2A26" BorderThickness="0,0,1,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="18">
                    <TextBlock Text="Театральная CRM" Foreground="#EEF5F1" FontSize="22" FontWeight="SemiBold"/>
                    <TextBlock Text="Одежда, реквизит, костюмы, спектакли и секторы" Foreground="#8EA39A" TextWrapping="Wrap" Margin="0,6,0,22" FontSize="14"/>

                    <Button Content="Одежда на подбор" Tag="{x:Static models:CatalogItemType.Clothing}" Click="SectionButton_Click" FontSize="14"/>
                    <Button Content="Реквизит" Tag="{x:Static models:CatalogItemType.Prop}" Click="SectionButton_Click" FontSize="14"/>
                    <Button Content="Костюмы" Tag="{x:Static models:CatalogItemType.Costume}" Click="SectionButton_Click" FontSize="14"/>
                    <Button Content="Спектакли" Tag="{x:Static models:CatalogItemType.Performance}" Click="SectionButton_Click" FontSize="14"/>
                    <Button Content="Секторы" Tag="{x:Static models:CatalogItemType.Sector}" Click="SectionButton_Click" Margin="0,12,0,4" FontSize="14"/>
                    <Button Content="Корзина" Click="TrashButton_Click" FontSize="14"/>

                    <!-- Сворачиваемый блок настроек (2.1) -->
                    <Expander Header="Настройки" Foreground="#EEF5F1" FontSize="14" IsExpanded="False" Margin="0,18,0,0">
                        <StackPanel>
                            <Button Content="Экспорт Excel" Click="ExportButton_Click" FontSize="14"/>
                            <Button Content="Импорт Excel" Click="ImportButton_Click" FontSize="14"/>
                            <Button Content="Восстановить backup" Click="RestoreBackupButton_Click" FontSize="14"/>
                            <Button Content="Пользователи" Click="ManageUsersButton_Click" FontSize="14" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Expander>

                    <TextBlock DockPanel.Dock="Bottom" Text="Данные хранятся локально рядом с приложением."
                               Foreground="#66776F" TextWrapping="Wrap" FontSize="12" Margin="0,22,0,0"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Центр: список и поиск -->
        <Grid Grid.Column="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Заголовок раздела -->
            <DockPanel Grid.Row="0" LastChildFill="False">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock x:Name="SectionTitle" Text="Одежда на подбор" Foreground="#EEF5F1" FontSize="28" FontWeight="SemiBold"/>
                    <TextBlock x:Name="SectionSubtitle" Text="0 карточек" Foreground="#8EA39A" Margin="0,4,0,0" FontSize="14"/>
                </StackPanel>
                <Button DockPanel.Dock="Right" x:Name="CreateButton" Content="Создать" Style="{StaticResource PrimaryButton}" Click="CreateButton_Click" MinWidth="120" Padding="18,9"/>
            </DockPanel>

            <!-- Строка поиска и фильтр -->
            <Grid Grid.Row="1" Margin="0,18,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" x:Name="SearchBox"
                         TextChanged="SearchBox_TextChanged"
                         ToolTip="Фильтр по всем полям карточки" FontSize="14"/>
                <Button Grid.Column="1" x:Name="FilterButton" Content="Фильтр" Margin="12,4,0,4" Click="FilterButton_Click" Padding="18,9" MinWidth="100" FontSize="14"/>
                <Button Grid.Column="2" Content="Сбросить" Margin="12,4,0,4" Click="ClearFiltersButton_Click" Padding="18,9" MinWidth="100" FontSize="14"/>
            </Grid>

            <!-- Список сущностей -->
            <ListBox Grid.Row="2" x:Name="ItemsList" Background="Transparent" BorderThickness="0"
                     SelectionChanged="ItemsList_SelectionChanged"
                     MouseDoubleClick="ItemsList_MouseDoubleClick"
                     ScrollViewer.CanContentScroll="True"
                     VirtualizingPanel.IsVirtualizing="True">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:CatalogItem}">
                        <Border Background="#17201D" BorderBrush="#26342F" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,5,0,5">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}" Foreground="#EEF5F1" FontSize="17" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Description}" Foreground="#B8C7C0" TextTrimming="CharacterEllipsis" Margin="0,5,0,0" FontSize="14"/>
                                    <TextBlock Text="{Binding Subtitle}" Foreground="#8EA39A" Margin="0,7,0,0" FontSize="14"/>
                                    <TextBlock Text="{Binding SectorsText}" Foreground="#48D08B" Margin="0,7,0,0" FontSize="14"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{Binding UpdatedAt, StringFormat='{}{0:dd.MM.yyyy}'}"
                                           Foreground="#66776F" VerticalAlignment="Top" Margin="16,0,0,0" FontSize="14"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <!-- Шторка (GridSplitter) между списком и превью -->
        <GridSplitter Grid.Column="2" Width="6" Background="#1E2A26" 
                      ResizeBehavior="PreviousAndNext"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"/>

        <!-- Правая панель: превью карточки + история -->
        <Border Grid.Column="3" Background="#121917" BorderBrush="#1E2A26" BorderThickness="1,0,0,0">
            <ScrollViewer>
                <StackPanel Margin="22">
                    <TextBlock Text="Карточка" Foreground="#EEF5F1" FontSize="22" FontWeight="SemiBold"/>
                    <Image x:Name="DetailsImage" Height="350" Stretch="Uniform" Margin="0,16,0,12"/>
                    <TextBlock x:Name="DetailsTitle" Text="Выберите карточку" Foreground="#EEF5F1" FontSize="20" FontWeight="SemiBold" TextWrapping="Wrap"/>
                    <TextBlock x:Name="DetailsDescription" Foreground="#B8C7C0" Margin="0,10,0,0" TextWrapping="Wrap" FontSize="14"/>
                    <TextBlock x:Name="DetailsMeta" Foreground="#8EA39A" Margin="0,14,0,0" TextWrapping="Wrap" FontSize="14"/>
                    <TextBlock Text="Связи" Foreground="#EEF5F1" FontSize="16" FontWeight="SemiBold" Margin="0,22,0,8"/>
                    <ItemsControl x:Name="RelatedItems">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:CatalogSummary}">
                                <Button Content="{Binding Display}" Tag="{Binding}" Click="RelatedItem_Click" HorizontalContentAlignment="Left" FontSize="14"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Кнопки действий -->
                    <StackPanel x:Name="MainButtons" Orientation="Vertical" Margin="0,16,0,0">
                        <Button Content="Редактировать" Click="EditButton_Click" MinWidth="140" MaxWidth="250" FontSize="14"/>
                        <Button Content="Удалить" Click="DeleteButton_Click" MinWidth="140" MaxWidth="250" Background="#3A1D22" BorderBrush="#6A2E37" FontSize="14"/>
                    </StackPanel>

                    <!-- Кнопки "Удалить навсегда" и "Восстановить" - только в корзине (2.4) -->
                    <StackPanel x:Name="TrashButtons" Orientation="Vertical" Margin="0,8,0,0" Visibility="Collapsed">
                        <Button Content="Восстановить" Click="RestoreItemButton_Click" MinWidth="140" MaxWidth="250" FontSize="14"/>
                        <Button Content="Удалить навсегда" Click="PermanentDeleteButton_Click" MinWidth="140" MaxWidth="250" Background="#3A1D22" BorderBrush="#6A2E37" FontSize="14"/>
                    </StackPanel>

                    <!-- Сворачиваемый блок истории (2.6) -->
                    <Expander x:Name="HistoryExpander" Header="История" Foreground="#EEF5F1" FontSize="16" FontWeight="SemiBold"
                              IsExpanded="False" Margin="0,16,0,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" MaxHeight="250">
                            <ItemsControl x:Name="AuditItems"/>
                        </ScrollViewer>
                    </Expander>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>