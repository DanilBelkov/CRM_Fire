<Window x:Class="TheatreCRM.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:TheatreCRM.App.Models"
        Title="Театральная CRM" Height="760" Width="1240"
        MinHeight="640" MinWidth="1040"
        Background="#101413" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#EEF5F1"/>
            <Setter Property="Background" Value="#1D2925"/>
            <Setter Property="BorderBrush" Value="#2B3A35"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,9"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#21A66B"/>
            <Setter Property="BorderBrush" Value="#2CC77F"/>
            <Setter Property="Foreground" Value="#06110C"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="#EEF5F1"/>
            <Setter Property="Background" Value="#17201D"/>
            <Setter Property="BorderBrush" Value="#2B3A35"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="340"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#0C100F" BorderBrush="#1E2A26" BorderThickness="0,0,1,0">
            <DockPanel Margin="18">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="Театральная CRM" Foreground="#EEF5F1" FontSize="22" FontWeight="SemiBold"/>
                    <TextBlock Text="Одежда, реквизит, костюмы, спектакли" Foreground="#8EA39A" TextWrapping="Wrap" Margin="0,6,0,22"/>
                    <Button Content="Одежда" Tag="{x:Static models:CatalogItemType.Clothing}" Click="SectionButton_Click"/>
                    <Button Content="Реквизит" Tag="{x:Static models:CatalogItemType.Prop}" Click="SectionButton_Click"/>
                    <Button Content="Костюмы" Tag="{x:Static models:CatalogItemType.Costume}" Click="SectionButton_Click"/>
                    <Button Content="Спектакли" Tag="{x:Static models:CatalogItemType.Performance}" Click="SectionButton_Click"/>
                    <Button Content="Теги и группы" Click="TagsButton_Click" Margin="0,18,0,4"/>
                    <Button Content="Корзина" Click="TrashButton_Click"/>
                    <Button Content="Экспорт Excel" Click="ExportButton_Click" Margin="0,18,0,4"/>
                    <Button Content="Импорт Excel" Click="ImportButton_Click"/>
                    <Button Content="Создать backup" Click="BackupButton_Click"/>
                    <Button Content="Восстановить backup" Click="RestoreBackupButton_Click"/>

                    <TextBlock Text="Мои вкладки" Foreground="#EEF5F1" FontWeight="SemiBold" Margin="0,22,0,8"/>
                    <ItemsControl x:Name="SavedViewsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:SavedView}">
                                <Button Content="{Binding Name}" Tag="{Binding}" Click="SavedView_Click" HorizontalContentAlignment="Left"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
                <TextBlock DockPanel.Dock="Bottom" Text="Данные хранятся локально в папке data рядом с приложением."
                           Foreground="#66776F" TextWrapping="Wrap" FontSize="12"/>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" LastChildFill="False">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock x:Name="SectionTitle" Text="Одежда" Foreground="#EEF5F1" FontSize="28" FontWeight="SemiBold"/>
                    <TextBlock x:Name="SectionSubtitle" Text="0 карточек" Foreground="#8EA39A" Margin="0,4,0,0"/>
                </StackPanel>
                <Button DockPanel.Dock="Right" x:Name="CreateButton" Content="Создать" Style="{StaticResource PrimaryButton}" Click="CreateButton_Click" MinWidth="120"/>
            </DockPanel>

            <TextBox Grid.Row="1" x:Name="SearchBox" Margin="0,18,0,10"
                     TextChanged="SearchBox_TextChanged"
                     ToolTip="Поиск по названию и описанию"/>

            <Grid Grid.Row="2" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Группа тегов" Foreground="#8EA39A"/>
                    <ComboBox x:Name="TagGroupFilter" DisplayMemberPath="Name" SelectionChanged="TagGroupFilter_SelectionChanged"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="10,0,10,0">
                    <TextBlock Text="Тег" Foreground="#8EA39A"/>
                    <ComboBox x:Name="TagFilter" DisplayMemberPath="DisplayName" SelectionChanged="TagFilter_SelectionChanged"/>
                </StackPanel>
                <CheckBox Grid.Column="2" x:Name="GroupByTagCheck" Content="Группировать" Foreground="#EEF5F1"
                          VerticalAlignment="Bottom" Margin="10,0,16,10" Checked="GroupByTagCheck_Changed" Unchecked="GroupByTagCheck_Changed"/>
                <CheckBox Grid.Column="3" x:Name="SemanticSearchCheck" Content="Смысловой поиск" Foreground="#8EA39A"
                          IsEnabled="False" ToolTip="Опциональный локальный режим будет добавлен позже; сейчас используется быстрый FTS5."
                          VerticalAlignment="Bottom" Margin="0,0,16,10"/>
                <Button Grid.Column="4" Content="Сохранить вкладку" VerticalAlignment="Bottom" Click="SaveViewButton_Click"/>
                <Button Grid.Column="5" Content="Сбросить" VerticalAlignment="Bottom" Click="ClearFiltersButton_Click" Margin="10,4,0,4"/>
            </Grid>

            <ListBox Grid.Row="3" x:Name="ItemsList" Background="Transparent" BorderThickness="0"
                     SelectionChanged="ItemsList_SelectionChanged"
                     ScrollViewer.CanContentScroll="True"
                     VirtualizingPanel.IsVirtualizing="True">
                <ListBox.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate>
                                <Border Background="#0F2A20" CornerRadius="8" Padding="10,6" Margin="0,12,0,8">
                                    <TextBlock Text="{Binding Name}" Foreground="#48D08B" FontWeight="SemiBold"/>
                                </Border>
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                    </GroupStyle>
                </ListBox.GroupStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:CatalogItem}">
                        <Border Background="#17201D" BorderBrush="#26342F" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}" Foreground="#EEF5F1" FontSize="17" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Description}" Foreground="#B8C7C0" TextTrimming="CharacterEllipsis" Margin="0,5,0,0"/>
                                    <TextBlock Text="{Binding Subtitle}" Foreground="#8EA39A" Margin="0,7,0,0"/>
                                    <TextBlock Text="{Binding TagsText}" Foreground="#48D08B" Margin="0,7,0,0"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{Binding UpdatedAt, StringFormat='{}{0:dd.MM.yyyy}'}"
                                           Foreground="#66776F" VerticalAlignment="Top" Margin="16,0,0,0"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <Border Grid.Column="2" Background="#121917" BorderBrush="#1E2A26" BorderThickness="1,0,0,0">
            <ScrollViewer>
                <StackPanel Margin="22">
                    <TextBlock Text="Карточка" Foreground="#EEF5F1" FontSize="22" FontWeight="SemiBold"/>
                    <Image x:Name="DetailsImage" Height="350" Stretch="UniformToFill" Margin="0,16,0,12"/>
                    <TextBlock x:Name="DetailsTitle" Text="Выберите карточку" Foreground="#EEF5F1" FontSize="20" FontWeight="SemiBold" TextWrapping="Wrap"/>
                    <TextBlock x:Name="DetailsDescription" Foreground="#B8C7C0" Margin="0,10,0,0" TextWrapping="Wrap"/>
                    <TextBlock x:Name="DetailsMeta" Foreground="#8EA39A" Margin="0,14,0,0" TextWrapping="Wrap"/>
                    <TextBlock Text="Связи" Foreground="#EEF5F1" FontSize="16" FontWeight="SemiBold" Margin="0,22,0,8"/>
                    <ItemsControl x:Name="RelatedItems">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:CatalogSummary}">
                                <Button Content="{Binding Display}" Tag="{Binding}" Click="RelatedItem_Click" HorizontalContentAlignment="Left"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <StackPanel Orientation="Horizontal" Margin="0,22,0,0">
                        <Button Content="Редактировать" Click="EditButton_Click" MinWidth="138"/>
                        <Button Content="Удалить" Click="DeleteButton_Click" MinWidth="94" Margin="10,4,0,4" Background="#3A1D22" BorderBrush="#6A2E37"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="Восстановить" Click="RestoreItemButton_Click" MinWidth="138"/>
                        <Button Content="Удалить навсегда" Click="PermanentDeleteButton_Click" MinWidth="140" Margin="10,4,0,4" Background="#3A1D22" BorderBrush="#6A2E37"/>
                    </StackPanel>
                    <TextBlock Text="История" Foreground="#EEF5F1" FontSize="16" FontWeight="SemiBold" Margin="0,22,0,8"/>
                    <ItemsControl x:Name="AuditItems"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
