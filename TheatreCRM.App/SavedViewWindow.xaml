<Window x:Class="TheatreCRM.App.SavedViewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Сохранить вкладку" Height="260" Width="460"
        Background="#101413" WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#EEF5F1"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="#EEF5F1"/>
            <Setter Property="Background" Value="#17201D"/>
            <Setter Property="BorderBrush" Value="#2B3A35"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="9,7"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#EEF5F1"/>
            <Setter Property="Background" Value="#1D2925"/>
            <Setter Property="BorderBrush" Value="#2B3A35"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,9"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>
    </Window.Resources>
    <DockPanel Margin="24">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
            <Button Content="Отмена" Click="CancelButton_Click" MinWidth="96" Margin="0,4,10,4"/>
            <Button Content="Сохранить" Click="SaveButton_Click" MinWidth="120" Background="#21A66B" Foreground="#06110C"/>
        </StackPanel>
        <StackPanel>
            <TextBlock Text="Название вкладки" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12"/>
            <TextBox x:Name="NameBox"/>
            <CheckBox x:Name="ShowInSidebarBox" Content="Показывать в левой панели" Foreground="#EEF5F1" IsChecked="True" Margin="0,16,0,0"/>
            <TextBlock Text="Будут сохранены текущий раздел, выбранная группа тегов, тег и режим группировки."
                       Foreground="#8EA39A" TextWrapping="Wrap" Margin="0,16,0,0"/>
        </StackPanel>
    </DockPanel>
</Window>
